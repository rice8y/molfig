      "inputs": [
        "tests/fixtures/pdb/water.pdb",
        "tests/fixtures/cif/water.cif"
      ],
      "parse": {
        "atomCount": 3,
        "bondCount": 2,
        "models": 1,
        "residues": ["HOH"],
        "chains": ["A"],
        "elements": { "H": 2, "O": 1 },
        "bboxAngstrom": {
          "min": [-0.239, 0.0, 0.0],
          "max": [0.957, 0.927, 0.0]
        }
      },
      "exports": {
        "obj": {
          "requiredPrefixes": ["# molfig", "o water", "v ", "f "],
          "mustNotContain": ["nan", "undefined", "Infinity"],
          "minVertexCount": 24,
          "minFaceCount": 16
        },
        "stl": {
          "requiredPrefixes": ["solid water"],
          "mustContain": ["facet normal", "outer loop", "endfacet"],
          "mustNotContain": ["nan", "undefined", "Infinity"],
          "minTriangleCount": 16
        },
        "ply": {
          "requiredPrefixes": ["ply", "format ascii 1.0", "element vertex", "element face"],
